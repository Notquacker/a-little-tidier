{
  "name": "a-little-tidier",
  "productName": "Gails Game Room",
  "version": "2.0.0",
  "description": "Four cozy games, made with love for Gail (and Archy, Ice & Chip)",
  "main": "main.js",
  "author": "Xayvion",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.xayvion.alittletidier",
    "productName": "Gails Game Room",
    "files": [
      "main.js",
      "index.html",
      "tidier.html",
      "sudoku.html",
      "wordle.html",
      "salad.html",
      "shared.css",
      "shared.js",
      "manifest.json",
      "build/icon.png"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
